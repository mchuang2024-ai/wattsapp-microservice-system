FROM node:20-alpine

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json* frontend/pnpm-lock.yaml* ./
RUN npm install

COPY frontend/. ./

# Declare build-time variables so NEXT_PUBLIC_* values are embedded in the
# client-side bundle (Next.js resolves these at build time, not runtime).
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_BOOKING_URL
ARG NEXT_PUBLIC_DRIVER_URL
ARG NEXT_PUBLIC_VIEW_SLOTS_URL
ARG NEXT_PUBLIC_HANDLE_NOSHOW_URL
ARG NEXT_PUBLIC_REPORT_FAULT_URL

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_BOOKING_URL=$NEXT_PUBLIC_BOOKING_URL
ENV NEXT_PUBLIC_DRIVER_URL=$NEXT_PUBLIC_DRIVER_URL
ENV NEXT_PUBLIC_VIEW_SLOTS_URL=$NEXT_PUBLIC_VIEW_SLOTS_URL
ENV NEXT_PUBLIC_HANDLE_NOSHOW_URL=$NEXT_PUBLIC_HANDLE_NOSHOW_URL
ENV NEXT_PUBLIC_REPORT_FAULT_URL=$NEXT_PUBLIC_REPORT_FAULT_URL

RUN npm run build

EXPOSE 3000
CMD ["npm", "start"]
